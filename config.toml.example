# Sensitive-content filter for scripts/push_maccy_clips.sh — TEMPLATE.
#
# Copy this file to `config.toml` (which is git-ignored) and add any
# org-specific patterns there — an internal domain, a record-URL parameter,
# anything you never want leaving your machine. The two placeholder blocks
# below (`org-internal-domain`, `record-direct-link`) show where those go;
# replace them with your own. If `config.toml` is absent, the push script
# falls back to this example so filtering is never silently skipped.
#
# Every clipboard item is checked against each `regex` below before it is
# pushed to the shared Turso `clips` table. A match causes that item to be
# skipped — its cursor still advances, so it is never retried, but its text
# is never sent to Turso and is never printed to the log (only `name` is).
#
# Matching is case-insensitive (`grep -Eiq`) and uses POSIX extended regular
# expressions (ERE) only, on purpose: the plist runs this script through
# whatever `grep` ships on each Mac, which cannot be assumed to be a PCRE
# build. So: no `(?:...)`, no inline `(?i)`, no `\s`/`\d` — use `[[:space:]]`
# and plain `(...)` groups instead. Test a new pattern with
# `grep -Eiq -e '<regex>'` before adding it here.
#
# Format:
#   [[patterns]]
#   name  = "short-id"      # logged on skip; never the matched text itself
#   regex = 'raw ERE'       # ALWAYS single-quoted: TOML single-quoted
#                           # strings are literal, so a backslash reaches
#                           # grep unescaped. A double-quoted TOML string
#                           # would eat it first.
#
# To add a new pattern, copy a `[[patterns]]` block and edit `name`/`regex`.
# To disable one without deleting it, comment out its `regex` line with `#`.
#
# [[count_patterns]] is a different shape: it blocks on *how many* matching
# tokens appear, not on any single match (e.g. pasting a whole column of
# chart numbers, none of which individually looks like a secret). It needs
# three fields instead of one `regex`, because neither consumer engine has
# a portable single-expression way to say "count exactly-N-digit tokens":
#   name             = "short-id"
#   min_count        = 3            # block when matches >= this
#   shell_token_regex = 'raw ERE'   # grep -oE: candidate tokens to extract
#   shell_match_regex = 'raw ERE'   # grep -E:  which extracted tokens count
#   icu_regex         = 'raw ICU'   # Shortcut Match Text: same rule, but
#                                   # ICU has real \b word boundaries so it
#                                   # doesn't need the extract+filter split.

# --- Replace these two with your own org-specific patterns in config.toml ---

[[patterns]]
name = "org-internal-domain"
# e.g. your workplace/hospital domain, so internal links never leave the Mac.
regex = 'yourorg\.example'

[[patterns]]
name = "record-direct-link"
# e.g. the query params your record system puts in deep links.
regex = 'record_id=|record_key='

# --- Universal patterns below; keep as-is ---

[[patterns]]
name = "cookie-export-keys"
regex = '(httpOnly|sameSite|hostOnly|storeId|expirationDate)"[[:space:]]*:'

[[patterns]]
name = "jwt"
regex = 'eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+'

[[patterns]]
name = "generic-credential-kv"
# Trailing `"?` also catches JSON-quoted keys, e.g. "password":"hunter2".
regex = '(session|token|secret|password|passwd|api[_-]?key|apikey)"?[[:space:]]*[:=][[:space:]]*[^[:space:]]+'

[[patterns]]
name = "password-manager-csv-header"
# CSV/JSON vault exports (Chrome, 1Password, Bitwarden) put these two
# column names next to each other separated by a bare comma; ordinary
# prose almost never does. Requiring the comma (not just proximity) is
# what keeps this from tripping on a sentence like "reset your password,
# then check your username".
regex = '(username|login)[[:space:]]*,[[:space:]]*password|password[[:space:]]*,[[:space:]]*(username|login|url)'

[[patterns]]
name = "long-hex-hash"
regex = '[a-f0-9]{40,}'

[[patterns]]
name = "ssh-private-key"
regex = '-----BEGIN (RSA |OPENSSH |EC |DSA |ENCRYPTED )?PRIVATE KEY-----'

[[patterns]]
name = "aws-access-key-id"
regex = 'AKIA[0-9A-Z]{16}'

[[patterns]]
name = "aws-secret-key-kv"
regex = 'aws_secret_access_key[[:space:]]*[:=][[:space:]]*[^[:space:]]+'

[[patterns]]
name = "google-api-key"
regex = 'AIza[0-9A-Za-z_-]{35}'

[[patterns]]
name = "slack-token"
regex = 'xox[baprs]-[0-9A-Za-z-]{10,}'

[[patterns]]
name = "github-token"
regex = 'gh[pousr]_[A-Za-z0-9]{36,}'

[[patterns]]
name = "credit-card-16digit"
# Visa (4), Mastercard (51-55), Discover (6011, 65xx), 16 digits total,
# grouped by 4 with an optional space or dash between every group
# (covers both raw "4111111111111111" and "4111 1111 1111 1111"). The
# leading/trailing `(^|[^0-9])`/`([^0-9]|$)` matter: without them this
# matches unbounded, so an unrelated 20+ digit run (an account number, a
# sliced-up phone/order ID) can contain a "starts with 4, 16 digits long"
# substring purely by chance and false-trigger. POSIX ERE has no `\b`, so
# this is the portable stand-in — it works the same way in the ICU regex
# on the Shortcut side.
regex = '(^|[^0-9])(4[0-9]{3}|5[1-5][0-9]{2}|6011|65[0-9]{2})[ -]?[0-9]{4}[ -]?[0-9]{4}[ -]?[0-9]{4}([^0-9]|$)'

[[patterns]]
name = "credit-card-amex"
# Amex: prefix 34/37, 15 digits total, conventionally grouped 4-6-5.
# Bounded for the same reason as credit-card-16digit above.
regex = '(^|[^0-9])3[47][0-9]{2}[ -]?[0-9]{6}[ -]?[0-9]{5}([^0-9]|$)'

[[patterns]]
name = "crypto-wallet-phrase-label"
# Matches when a seed/recovery phrase is copied together with its own
# label, which is how wallet apps show it. Deliberately does NOT try to
# recognize a bare 12/24-word BIP39 phrase by word count alone — every
# ordinary lowercase, punctuation-free sentence of the same length would
# also match that, which is too noisy for a filter that runs silently.
# If you want that stricter (noisier) net anyway, add e.g.:
#   regex = '^([a-z]+[[:space:]]){11}[a-z]+$'   # exactly 12 words
regex = '(seed phrase|recovery phrase|secret recovery phrase|mnemonic)'

[[count_patterns]]
name = "bulk-8digit-numbers"
# A record number alone doesn't look like anything (it's just 8 digits),
# but pasting a whole column of them — a spreadsheet export, a batch
# lookup list — is itself a leak. `shell_token_regex` extracts every
# maximal run of digits; `shell_match_regex` keeps only the ones that are
# exactly 8 digits long, so a single long number (a 16-digit card, a
# 24-digit account number) can't get sliced into fake 8-digit "hits".
min_count = 3
shell_token_regex = '[0-9]+'
shell_match_regex = '^[0-9]{8}$'
icu_regex = '\b[0-9]{8}\b'
