# Optional defaults for Make. This file contains no credential.
# Load a local copy with: set -a; source .env; set +a

TURSO=/opt/homebrew/bin/turso
DB=clipboard-snap
ENDPOINT=https://your-database.turso.io/v2/pipeline
TOKEN_EXPIRATION=90d
PRIVATE_NAME="Clipboard Snap Configured"

# Never store TURSO_TOKEN here. Mint it only when importing or privately building.
